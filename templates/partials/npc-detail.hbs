<div class="hub-npc-detail">
	<div class="hub-view-header hub-npc-header">
		<h3>{{selected_actor.name}}</h3>
		<p class="hub-view-hint">{{localize "dc-npc-patrols.hub.npc_hint"}}</p>
	</div>

	<!-- Behaviour (primary) -->
	<div class="hub-npc-section hub-npc-section-primary">
		<div class="hub-npc-section-title">
			<i class="fa-solid fa-diagram-project"></i> {{localize "dc-npc-patrols.hub.section_behaviour"}}
		</div>
		<div class="hub-behaviour-row">
			<label class="hub-field-row hub-field-grow">
				<span>{{localize "dc-npc-patrols.bt.assign_bt"}}</span>
				<select data-bt-assign>
					<option value="">{{localize "dc-npc-patrols.bt.no_bt"}}</option>
					{{#each available_bts}}
					<option value="{{this.id}}" {{#if (eq this.id ../assigned_bt_id)}}selected{{/if}}>{{this.name}}</option>
					{{/each}}
				</select>
			</label>
			{{#if assigned_bt_id}}
			<button type="button" data-action="edit-assigned-bt" class="patrol-btn">
				<i class="fa-solid fa-pen"></i> {{localize "dc-npc-patrols.hub.edit_tree"}}
			</button>
			{{/if}}
		</div>
		{{#if assigned_bt_id}}
		{{#if bt_variable_fields.length}}
		<div class="hub-bt-variables hub-npc-subsection">
			<div class="hub-npc-subsection-title">{{localize "dc-npc-patrols.sheet.tree_variables"}}</div>
			{{> "modules/dc-npc-patrols/templates/partials/bt-variables-fields.hbs"}}
		</div>
		{{/if}}
		{{/if}}
	</div>

	<!-- Interactions -->
	<div class="hub-npc-section">
		<div class="hub-npc-section-title">
			<i class="fa-solid fa-handshake"></i> {{localize "dc-npc-patrols.hub.section_interactions"}}
		</div>
		{{> attachment-editor hub_mode=true}}
	</div>
</div>