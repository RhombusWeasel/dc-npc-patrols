<div class="waypoint-card">
	<div class="waypoint-card-header">
		<input type="text" data-wp-field="{{path_idx}}:{{wp_idx}}:label" value="{{waypoint.label}}" placeholder="{{localize 'dc-npc-patrols.panel.wp_label'}}" class="waypoint-card-label" />
		<input type="time" data-wp-field="{{path_idx}}:{{wp_idx}}:time" value="{{waypoint.time}}" class="time-input" />
		<button type="button" data-delete-waypoint="{{path_idx}}:{{wp_idx}}" class="patrol-btn patrol-btn-danger" title="{{localize 'dc-npc-patrols.panel.delete'}}">
			<i class="fa-solid fa-trash"></i>
		</button>
	</div>

	<div class="waypoint-card-primary">
		<label class="waypoint-card-field">
			<span>{{localize "dc-npc-patrols.panel.wp_scene"}}</span>
			<select data-wp-field="{{path_idx}}:{{wp_idx}}:scene_id">
				<option value="">{{localize "dc-npc-patrols.panel.current_scene"}}</option>
				{{#each scenes}}
				<option value="{{this.id}}" {{#if (eq this.id ../waypoint.scene_id)}}selected{{/if}}>{{this.name}}</option>
				{{/each}}
			</select>
		</label>
		<label class="waypoint-card-field waypoint-card-coord">
			<span>X</span>
			<input type="number" data-wp-field="{{path_idx}}:{{wp_idx}}:x" value="{{waypoint.x}}" class="number-input" />
		</label>
		<label class="waypoint-card-field waypoint-card-coord">
			<span>Y</span>
			<input type="number" data-wp-field="{{path_idx}}:{{wp_idx}}:y" value="{{waypoint.y}}" class="number-input" />
		</label>
		<div class="waypoint-card-route">
			<span class="route-badge {{#unless waypoint.route.length}}route-empty{{/unless}}">{{#if waypoint.route.length}}{{waypoint.route.length}}{{else}}0{{/if}}</span>
			<span class="waypoint-card-route-label">{{localize "dc-npc-patrols.panel.wp_route"}}</span>
		</div>
	</div>

	<details class="waypoint-card-advanced">
		<summary>{{localize "dc-npc-patrols.hub.waypoint_advanced"}}</summary>
		<div class="waypoint-card-advanced-body">
			<label class="waypoint-card-field waypoint-card-full">
				<span>{{localize "dc-npc-patrols.panel.wp_arrival_lines"}}</span>
				<textarea data-wp-field="{{path_idx}}:{{wp_idx}}:arrival_lines">{{#each waypoint.arrival_lines}}{{this}}{{#unless @last}}
{{/unless}}{{/each}}</textarea>
			</label>
			<label class="waypoint-card-field">
				<span>{{localize "dc-npc-patrols.panel.wp_face_dir"}}</span>
				<input type="number" data-wp-field="{{path_idx}}:{{wp_idx}}:face_direction" value="{{waypoint.face_direction}}" class="number-input" />
			</label>
			<label class="waypoint-card-field">
				<span>{{localize "dc-npc-patrols.panel.wp_linger"}}</span>
				<input type="number" data-wp-field="{{path_idx}}:{{wp_idx}}:linger_minutes" value="{{waypoint.linger_minutes}}" class="number-input" />
			</label>
			<label class="waypoint-card-field">
				<span>{{localize "dc-npc-patrols.panel.wp_region_radius"}}</span>
				<input type="number" data-wp-field="{{path_idx}}:{{wp_idx}}:region_radius" value="{{waypoint.region_radius}}" class="number-input" />
			</label>
			<label class="waypoint-card-check">
				<input type="checkbox" data-wp-field="{{path_idx}}:{{wp_idx}}:flee_target" {{#if waypoint.flee_target}}checked{{/if}} />
				{{localize "dc-npc-patrols.bt.wp_flee_target"}}
			</label>
			<label class="waypoint-card-check">
				<input type="checkbox" data-wp-field="{{path_idx}}:{{wp_idx}}:home" {{#if waypoint.home}}checked{{/if}} />
				{{localize "dc-npc-patrols.bt.wp_home"}}
			</label>
		</div>
	</details>
</div>
