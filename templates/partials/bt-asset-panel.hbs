<div class="bt-asset-panel">
	<div class="bt-asset-filter">
		<button type="button" data-asset-filter="all" class="bt-asset-filter-btn {{#if (eq asset_filter 'all')}}active{{/if}}">
			{{localize "dc-npc-patrols.bt.asset_filter_all"}}
		</button>
		<button type="button" data-asset-filter="tree" class="bt-asset-filter-btn {{#if (eq asset_filter 'tree')}}active{{/if}}">
			{{localize "dc-npc-patrols.bt.asset_filter_trees"}}
		</button>
		<button type="button" data-asset-filter="fragment" class="bt-asset-filter-btn {{#if (eq asset_filter 'fragment')}}active{{/if}}">
			{{localize "dc-npc-patrols.bt.asset_filter_fragments"}}
		</button>
	</div>
	<div class="editor-asset-list">
		{{#each bts}}
		<div class="editor-asset-item">
			<button type="button" data-bt-select="{{this.id}}" class="editor-asset-btn {{#if (eq this.id ../selected_bt_id)}}active{{/if}}">
				<i class="fa-solid fa-diagram-project"></i>
				{{#if this.is_fragment}}<span class="bt-fragment-badge">{{localize "dc-npc-patrols.bt.fragment_badge"}}</span>{{/if}}
				{{this.name}}
			</button>
			<button type="button" data-bt-delete="{{this.id}}" class="editor-asset-delete" title="{{localize 'dc-npc-patrols.dialog.delete_tree'}}">
				<i class="fa-solid fa-trash"></i>
			</button>
		</div>
		{{/each}}
	</div>
	<div class="bt-io-row">
		<button type="button" data-action="export-bt" class="editor-add-btn bt-io-btn" {{#unless selected_bt_id}}disabled{{/unless}}>
			<i class="fa-solid fa-download"></i> {{localize "dc-npc-patrols.bt.export_tree"}}
		</button>
		<button type="button" data-action="import-bt" class="editor-add-btn bt-io-btn">
			<i class="fa-solid fa-upload"></i> {{localize "dc-npc-patrols.bt.import_tree"}}
		</button>
		<input type="file" accept=".json,application/json" data-bt-import-input hidden />
	</div>
	<button type="button" data-action="add-bt" class="editor-add-btn">
		<i class="fa-solid fa-plus"></i> {{localize "dc-npc-patrols.bt.new_tree"}}
	</button>
	<button type="button" data-action="add-fragment" class="editor-add-btn">
		<i class="fa-solid fa-plus"></i> {{localize "dc-npc-patrols.bt.new_fragment"}}
	</button>

	{{#if selected_bt}}
	<details class="editor-asset-settings" data-settings-panel="tree">
		<summary>{{localize "dc-npc-patrols.editor.tree_settings"}}</summary>
		<label class="editor-field">
			<span>{{localize "dc-npc-patrols.dialog.tree_name"}}</span>
			<input type="text" data-bt-field="name" value="{{selected_bt.name}}" />
		</label>
		<label class="editor-field">
			<span>{{localize "dc-npc-patrols.dialog.tree_desc"}}</span>
			<input type="text" data-bt-field="description" value="{{selected_bt.description}}" />
		</label>
		<label class="editor-field">
			<span>{{localize "dc-npc-patrols.editor.kind"}}</span>
			<select data-bt-field="kind">
				<option value="tree" {{#if (eq selected_kind 'tree')}}selected{{/if}}>{{localize "dc-npc-patrols.bt.kind_tree"}}</option>
				<option value="fragment" {{#if (eq selected_kind 'fragment')}}selected{{/if}}>{{localize "dc-npc-patrols.bt.kind_fragment"}}</option>
			</select>
		</label>
	</details>

	<details class="editor-asset-settings" data-settings-panel="variables">
		<summary>{{localize "dc-npc-patrols.editor.variables"}}</summary>
		<div class="bt-variables-table">
			<div class="bt-var-row bt-var-header">
				<span>Key</span>
				<span>Label</span>
				<span>Type</span>
				<span>Default</span>
				<span></span>
			</div>
			{{#each selected_bt.variables}}
			<div class="bt-var-row" data-var-index="{{@index}}">
				<input type="text" data-var-field="key" value="{{this.key}}" placeholder="key" {{#if this.key}}readonly{{/if}} />
				<input type="text" data-var-field="label" value="{{this.label}}" placeholder="Label" />
				<select data-var-field="type">
					{{#each ../var_types}}
					<option value="{{this.id}}" {{#if (eq this.id ../type)}}selected{{/if}}>{{this.label}}</option>
					{{/each}}
				</select>
				<input type="text" data-var-field="default" value="{{this.default}}" placeholder="(blank)" />
				<button type="button" data-var-delete="{{@index}}" class="editor-asset-delete"><i class="fa-solid fa-trash"></i></button>
			</div>
			{{/each}}
		</div>
		<button type="button" data-action="add-variable" class="editor-add-btn editor-add-btn-inline">
			<i class="fa-solid fa-plus"></i> {{localize "dc-npc-patrols.editor.add_variable"}}
		</button>
	</details>
	{{/if}}
</div>
