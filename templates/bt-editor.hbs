<form class="dc-bt-editor editor-shell editor-shell-3col">
	<aside class="editor-panel editor-panel-assets">
		<header class="editor-panel-header">{{localize "dc-npc-patrols.editor.assets"}}</header>
		<div class="editor-panel-body">{{> bt-asset-panel}}</div>
		<footer class="editor-panel-footer">
			<p class="editor-hint">{{localize "dc-npc-patrols.hub.world_bt_hint"}}</p>
		</footer>
	</aside>

	<section class="editor-panel editor-panel-structure">
		<header class="editor-panel-header">
			<span>{{localize "dc-npc-patrols.editor.structure"}}</span>
			{{#if selected_bt.name}}
			<span class="editor-panel-subtitle">{{selected_bt.name}}</span>
			{{/if}}
		</header>
		<div class="editor-panel-body">{{> bt-structure-panel}}</div>
	</section>

	<section class="editor-panel editor-panel-detail">
		<header class="editor-panel-header">{{localize "dc-npc-patrols.editor.detail"}}</header>
		<div class="editor-panel-body">{{> bt-detail-panel}}</div>
	</section>
</form>
